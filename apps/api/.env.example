# Database (PostgreSQL)
DATABASE_URL="postgresql://espanolpro:espanolpro_secret@localhost:5432/espanolpro"

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=another_long_random_secret_for_refresh_tokens
JWT_REFRESH_EXPIRES_IN=7d

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Zoom
ZOOM_API_KEY=
ZOOM_API_SECRET=

# Resend (email)
RESEND_API_KEY=re_...

# File storage (local dev)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
